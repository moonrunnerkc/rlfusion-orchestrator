# Copy this file to .env (gitignored) and edit for your host.
# Anything here is loaded into the environment before backend/config.yaml
# is parsed, so values here override what get_inference_config() returns.

# ----- Inference engine -----
# Pick the engine you want to use. Leave commented to let
# backend/core/engine_detect.resolve_inference_config() choose.
#   ollama          - hit a running ollama daemon
#   llama_cpp_dual  - load the Qwen 1.5B + Llama 3.1 8B GGUFs locally
#   vllm / tensorrt - OpenAI-compatible HTTP endpoint
# INFERENCE_ENGINE=ollama

# Pick a specific ollama model. If unset, the resolver picks the best
# installed local model (general chat preferred, 15-40 GB band preferred).
# Examples:
# INFERENCE_MODEL=gemma4:31b-it-q8_0
# INFERENCE_MODEL=llama3.3:70b
# INFERENCE_MODEL=qwen3.5:27b

# Override the daemon URL if ollama isn't on the default port.
# INFERENCE_BASE_URL=http://localhost:11434

# ----- Compute device -----
# auto    - cuda if available, else mps on Apple Silicon, else cpu
# cpu     - force CPU even if GPU is present
# cuda    - force CUDA (fails if unavailable)
# mps     - force Apple Silicon GPU
# RLFUSION_DEVICE=auto
# RLFUSION_FORCE_CPU=true

# ----- Admin -----
# Required to call POST /api/fine-tune. Pick a long random string.
# RLFUSION_ADMIN_KEY=replace-with-something-secret
